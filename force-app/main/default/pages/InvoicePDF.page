<apex:page renderAs="pdf" controller="InvoicePDFController">

    <h2>Invoice: {!formattedInvoiceNumber}</h2>
    <hr/>
    <div class="">
        <p>Account: {!invoiceHeader.Account__r.name}</p>
        <p>Opportunity: {!invoiceHeader.Opportunity__r.name}</p>
        <p>Date: {!invoiceHeader.CreatedDate}</p>
    </div>

    <table border="1" width="100%" cellpadding="5">
        <tr>
            <th>Product</th>
            <th>Qty</th>
            <th>Price</th>
            <th>Total</th>
        </tr>

        <apex:repeat value="{!lines}" var="l">
            <tr>
                <td>{!l.Product__r.Name}</td>
                <td>{!l.Quantity__c}</td>
                <td>{!l.Price__c}</td>
                <td>{!l.Total__c}</td>
            </tr>
        </apex:repeat>

    </table>

</apex:page>